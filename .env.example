# ============================================================================
# World Cup 2026 Predictor
# ============================================================================
#
# Copy this file to .env and configure the required values.
#
# Example:
#   cp .env.example .env
#
# ============================================================================

# ----------------------------------------------------------------------------
# Flask
# ----------------------------------------------------------------------------

# Generate a key with:
# python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=

# ----------------------------------------------------------------------------
# Public URL
# ----------------------------------------------------------------------------

# Examples:
# HOST_URL=https://brackets.example.com
# HOST_URL=https://worldcup.yourdomain.com
# HOST_URL=http://192.168.1.100:5000

HOST_URL=

# ----------------------------------------------------------------------------
# Initial Admin Account
# ----------------------------------------------------------------------------

# Used to create the first administrator account.

INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------

# These files are generated by install.sh.

JWT_PRIVATE_KEY_FILE=jwt_private.pem
JWT_PUBLIC_KEY_FILE=jwt_public.pem

# Access token lifetime (seconds)
JWT_ACCESS_TOKEN_EXPIRES=900

# Refresh token lifetime (seconds)
JWT_REFRESH_TOKEN_EXPIRES=28800

# ----------------------------------------------------------------------------
# HTTPS
# ----------------------------------------------------------------------------

# Set to 1 if running behind HTTPS and you want HTTP requests redirected.
# Leave as 0 when accessing directly via HTTP.

FORCE_HTTPS=0

# ----------------------------------------------------------------------------
# API-Football
# ----------------------------------------------------------------------------

# Get an API key from:
# https://dashboard.api-football.com

API_FOOTBALL_KEY=

# Live data polling interval in seconds.
#
# Suggested values:
#   60  = Active match days
#   300 = Recommended default
#   900 = Conservative / free-tier friendly

LIVE_SYNC_INTERVAL_SECONDS=300

# Set to 1 to disable all live data synchronisation.

DISABLE_LIVE_SYNC=0

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------

# install.sh will create the database and output the connection string.
#
# Paste the generated DATABASE_URL below.
#
# Example:
# DATABASE_URL=postgresql://worldcup:password@127.0.0.1:5432/worldcup

DATABASE_URL=
